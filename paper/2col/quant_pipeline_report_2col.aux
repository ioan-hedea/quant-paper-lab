\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces High-level architecture of the revised quantitative trading pipeline. The alpha layer is intentionally finance-first, the allocator builds a capped and turnover-aware target book, and the control comparison focuses on how much of that book to express rather than on a second stock-selection problem. The compared control families span simple rules, contextual bandits, supervised control, robust optimization, and RL.}}{18}{figure.caption.2}\protected@file@percent }
\newlabel{fig:architecture}{{1}{18}{High-level architecture of the revised quantitative trading pipeline. The alpha layer is intentionally finance-first, the allocator builds a capped and turnover-aware target book, and the control comparison focuses on how much of that book to express rather than on a second stock-selection problem. The compared control families span simple rules, contextual bandits, supervised control, robust optimization, and RL}{figure.caption.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Control-method overview plots for the two archived universes. Left: Universe A, where \texttt  {D\_plus\_convexity} is the flagship performer. Right: Universe B, where the robust frontier is tighter and plain \texttt  {D\_cvar\_robust} leads on mean Sharpe.}}{18}{figure.caption.17}\protected@file@percent }
\newlabel{fig:control_overview}{{2}{18}{Control-method overview plots for the two archived universes. Left: Universe A, where \texttt {D\_plus\_convexity} is the flagship performer. Right: Universe B, where the robust frontier is tighter and plain \texttt {D\_cvar\_robust} leads on mean Sharpe}{figure.caption.17}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Split-stability heatmaps for the control-comparison suite in the two universes. These plots summarize how controller rankings change across the three train-fraction splits.}}{18}{figure.caption.18}\protected@file@percent }
\newlabel{fig:split_heatmaps}{{3}{18}{Split-stability heatmaps for the control-comparison suite in the two universes. These plots summarize how controller rankings change across the three train-fraction splits}{figure.caption.18}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Pareto frontiers in return--drawdown space for the two archived universes. Universe A shows the strongest outward push from \texttt  {D\_plus\_convexity}; Universe B is tighter, with plain \texttt  {D\_cvar\_robust}, \texttt  {E\_council}, and \texttt  {H\_mpc} clustering near the defensive frontier.}}{19}{figure.caption.19}\protected@file@percent }
\newlabel{fig:control_heatmaps}{{4}{19}{Pareto frontiers in return--drawdown space for the two archived universes. Universe A shows the strongest outward push from \texttt {D\_plus\_convexity}; Universe B is tighter, with plain \texttt {D\_cvar\_robust}, \texttt {E\_council}, and \texttt {H\_mpc} clustering near the defensive frontier}{figure.caption.19}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Interpretability diagnostics for the reference split in both universes. The left panel in each image shows how the learned gate reallocates weight across experts through time; the right panel shows convexity mode usage by regime.}}{19}{figure.caption.20}\protected@file@percent }
\newlabel{fig:interpretability}{{5}{19}{Interpretability diagnostics for the reference split in both universes. The left panel in each image shows how the learned gate reallocates weight across experts through time; the right panel shows convexity mode usage by regime}{figure.caption.20}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Left-tail empirical distribution diagnostics for the reference split in both universes. In Universe A, \texttt  {D+} visibly improves the worst-return mass relative to plain \texttt  {D}; in Universe B, the tail improvement is smaller, matching the tighter D-versus-D+ ranking in the tables.}}{19}{figure.caption.21}\protected@file@percent }
\newlabel{fig:taildiagnostic}{{6}{19}{Left-tail empirical distribution diagnostics for the reference split in both universes. In Universe A, \texttt {D+} visibly improves the worst-return mass relative to plain \texttt {D}; in Universe B, the tail improvement is smaller, matching the tighter D-versus-D+ ranking in the tables}{figure.caption.21}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces MPC diagnostics for the reference split in both universes. The plots show planned versus realized invested fraction, stabilizer mix, and stress annotations, clarifying why \texttt  {H\_mpc} sits on the low-drawdown frontier.}}{20}{figure.caption.22}\protected@file@percent }
\newlabel{fig:mpcdiag}{{7}{20}{MPC diagnostics for the reference split in both universes. The plots show planned versus realized invested fraction, stabilizer mix, and stress annotations, clarifying why \texttt {H\_mpc} sits on the low-drawdown frontier}{figure.caption.22}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Legacy pruning-story diagnostics for Universes A and B. These remain useful as historical negative-reference evidence showing why the paper moved away from the old RL-heavy stack.}}{20}{figure.caption.23}\protected@file@percent }
\newlabel{fig:legacy_pruning}{{8}{20}{Legacy pruning-story diagnostics for Universes A and B. These remain useful as historical negative-reference evidence showing why the paper moved away from the old RL-heavy stack}{figure.caption.23}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Rolling-window robustness diagnostics for the retained legacy full pipeline in both universes. The pattern remains mixed, and the windows should be interpreted as internal robustness slices from one historical sample rather than independent replications.}}{20}{figure.caption.24}\protected@file@percent }
\newlabel{fig:rollingwindows}{{9}{20}{Rolling-window robustness diagnostics for the retained legacy full pipeline in both universes. The pattern remains mixed, and the windows should be interpreted as internal robustness slices from one historical sample rather than independent replications}{figure.caption.24}{}}
\@writefile{lot}{\contentsline {table}{\numberline {11}{\ignorespaces Complete Universe-A reference-split pairwise significance table for \texttt  {D+} versus every controller plus SPY (Sharpe deltas).}}{21}{table.caption.16}\protected@file@percent }
\newlabel{tab:dplus_significance_full}{{11}{21}{Complete Universe-A reference-split pairwise significance table for \texttt {D+} versus every controller plus SPY (Sharpe deltas)}{table.caption.16}{}}
