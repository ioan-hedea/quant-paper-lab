\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Pareto frontier in return--drawdown space for the finished 19-controller comparison. No single method dominates every metric. Plain \texttt  {D\_cvar\_robust} delivers high return but deep drawdown, the simple-rule controllers anchor the conservative end of the frontier, and \texttt  {D\_plus\_convexity} moves the robust optimizer toward a substantially better overall trade-off by keeping high return while materially reducing drawdown.}}{13}{figure.caption.10}\protected@file@percent }
\newlabel{fig:control_heatmaps}{{3}{13}{Pareto frontier in return--drawdown space for the finished 19-controller comparison. No single method dominates every metric. Plain \texttt {D\_cvar\_robust} delivers high return but deep drawdown, the simple-rule controllers anchor the conservative end of the frontier, and \texttt {D\_plus\_convexity} moves the robust optimizer toward a substantially better overall trade-off by keeping high return while materially reducing drawdown}{figure.caption.10}{}}
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Legacy ablation summary across train/test split settings. The factor-only row belongs to the archived pruning suite used to diagnose the old RL-heavy stack and is not directly comparable to the control-comparison factor-only baseline in Table~\ref {tab:metrics}.}}{14}{table.caption.11}\protected@file@percent }
\newlabel{tab:ablation_summary}{{6}{14}{Legacy ablation summary across train/test split settings. The factor-only row belongs to the archived pruning suite used to diagnose the old RL-heavy stack and is not directly comparable to the control-comparison factor-only baseline in Table~\ref {tab:metrics}}{table.caption.11}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Legacy pruning story from the retained ablation suite. The left panel orders the old architecture variants by mean Sharpe; the right panel shows the pruning path in return-versus-drawdown space. Its role in the revised paper is diagnostic: it explains why the study moved away from defending the old RL stack and toward a broader control-method comparison.}}{14}{figure.caption.12}\protected@file@percent }
\newlabel{fig:legacy_pruning}{{4}{14}{Legacy pruning story from the retained ablation suite. The left panel orders the old architecture variants by mean Sharpe; the right panel shows the pruning path in return-versus-drawdown space. Its role in the revised paper is diagnostic: it explains why the study moved away from defending the old RL stack and toward a broader control-method comparison}{figure.caption.12}{}}
