\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Split-by-split stability across the 13 control methods. The left panel shows Sharpe by train fraction; the right panel shows absolute maximum drawdown. The figure highlights both the breadth of the CVaR-robust point-estimate lead and the fact that it does not dominate every downside metric, especially realized maximum drawdown.}}{13}{figure.caption.6}\protected@file@percent }
\newlabel{fig:control_heatmaps}{{3}{13}{Split-by-split stability across the 13 control methods. The left panel shows Sharpe by train fraction; the right panel shows absolute maximum drawdown. The figure highlights both the breadth of the CVaR-robust point-estimate lead and the fact that it does not dominate every downside metric, especially realized maximum drawdown}{figure.caption.6}{}}
