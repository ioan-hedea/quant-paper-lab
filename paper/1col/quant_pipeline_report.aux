\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Control-comparison overview of the March 30 frozen-bundle. The four panels rank all controllers by mean Sharpe, summarize return--drawdown trade-offs, report the best method in each controller family, and show Sharpe stability across train fractions. \texttt  {D+} leads overall, plain \texttt  {D} is the strongest non-extension baseline, and the MLP meta-controller is the strongest learned challenger.}}{16}{figure.caption.9}\protected@file@percent }
\newlabel{fig:control_overview}{{2}{16}{Control-comparison overview of the March 30 frozen-bundle. The four panels rank all controllers by mean Sharpe, summarize return--drawdown trade-offs, report the best method in each controller family, and show Sharpe stability across train fractions. \texttt {D+} leads overall, plain \texttt {D} is the strongest non-extension baseline, and the MLP meta-controller is the strongest learned challenger}{figure.caption.9}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {8.2}Legacy Ablation and Complexity Pruning}{16}{subsection.8.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Pareto frontier in return--drawdown space for the finished 19-controller comparison. No single method dominates every metric. Plain \texttt  {D\_cvar\_robust} delivers high return but deep drawdown, the simple-rule controllers anchor the conservative end of the frontier, and \texttt  {D\_plus\_convexity} moves the robust optimizer toward a substantially better overall trade-off by keeping high return while materially reducing drawdown.}}{17}{figure.caption.10}\protected@file@percent }
\newlabel{fig:control_heatmaps}{{3}{17}{Pareto frontier in return--drawdown space for the finished 19-controller comparison. No single method dominates every metric. Plain \texttt {D\_cvar\_robust} delivers high return but deep drawdown, the simple-rule controllers anchor the conservative end of the frontier, and \texttt {D\_plus\_convexity} moves the robust optimizer toward a substantially better overall trade-off by keeping high return while materially reducing drawdown}{figure.caption.10}{}}
