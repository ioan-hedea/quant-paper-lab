\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Interpretability diagnostics for the revised extensions. Left: shaded 2020-crash and 2022-bear windows show that the reference-split MLP meta-controller remains centered on \texttt  {D\_cvar\_robust} while adjusting most around regime transitions. Right: convexity mode usage for \texttt  {D\_plus\_convexity} shifts from mostly \texttt  {none} in bull states to mostly \texttt  {strong} in bear states. Together the panels support the paper's headline mechanism claim: the gains come from state-dependent distribution shaping and expert selection, not from a new predictive signal.}}{23}{figure.caption.18}\protected@file@percent }
\newlabel{fig:interpretability}{{5}{23}{Interpretability diagnostics for the revised extensions. Left: shaded 2020-crash and 2022-bear windows show that the reference-split MLP meta-controller remains centered on \texttt {D\_cvar\_robust} while adjusting most around regime transitions. Right: convexity mode usage for \texttt {D\_plus\_convexity} shifts from mostly \texttt {none} in bull states to mostly \texttt {strong} in bear states. Together the panels support the paper's headline mechanism claim: the gains come from state-dependent distribution shaping and expert selection, not from a new predictive signal}{figure.caption.18}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {9.4}Control Versus Learning in Noisy Environments}{23}{subsection.9.4}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Mechanism diagnostic.}{23}{paragraph*.17}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {9.5}When Practitioners Should Use Which Control Style}{23}{subsection.9.5}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Left-tail empirical distribution diagnostic for the reference split. Compared with factor-only and plain CVaR, \texttt  {D+} shifts the worst-return mass inward and improves the 5\% tail summary while leaving average return roughly unchanged relative to plain \texttt  {D}. The figure supports the paper's main mechanism claim: the improvement of \texttt  {D+} is driven primarily by tail-risk reduction rather than by higher average returns alone. At the reference split, D+ improves 5\% CVaR by about 30 bps versus plain D.}}{24}{figure.caption.19}\protected@file@percent }
\newlabel{fig:taildiagnostic}{{6}{24}{Left-tail empirical distribution diagnostic for the reference split. Compared with factor-only and plain CVaR, \texttt {D+} shifts the worst-return mass inward and improves the 5\% tail summary while leaving average return roughly unchanged relative to plain \texttt {D}. The figure supports the paper's main mechanism claim: the improvement of \texttt {D+} is driven primarily by tail-risk reduction rather than by higher average returns alone. At the reference split, D+ improves 5\% CVaR by about 30 bps versus plain D}{figure.caption.19}{}}
